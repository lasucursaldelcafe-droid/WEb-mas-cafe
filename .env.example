# Firebase — mas-cafe-c8413 (legacy — wallet ya usa Supabase)
FIREBASE_PROJECT_ID=mas-cafe-c8413

# ── Supabase wallet (plan gratuito) ─────────────────────────────
# Supabase → Settings → API (nuevo formato sb_publishable / sb_secret)
SUPABASE_URL=https://TU-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy (también válido): SUPABASE_ANON_KEY=  SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
# Settings → General → Reference ID (opcional si URL está arriba)
SUPABASE_PROJECT_REF=

# ── Google Wallet (tarjeta nativa Android — Google Cloud, no Firebase) ──
# Valores públicos también en content/google-wallet.json
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_PAY_MERCHANT_ID=BCR2DN5TR7J4FLAR
GOOGLE_WALLET_ISSUER_ID=3388000000023162431
# Pega el JSON descargado de GCP en secrets/google-wallet-sa.json (ver secrets/README.md)
GOOGLE_APPLICATION_CREDENTIALS=secrets/google-wallet-sa.json
# Alternativa: JSON en una sola línea (CI / GitHub Actions)
# GOOGLE_WALLET_SERVICE_ACCOUNT=
# Opcional: Maps u otras APIs Google en el sitio
GOOGLE_API_KEY=
# Opcional: keytool -list -v (app Android nativa)
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=androiddebugkey
# Automatizar: npm run wallet:google-bootstrap && npm run wallet:google-auto

# GitHub PAT (repo + secrets) — para npm run wallet:connect
GITHUB_TOKEN=

# Conectar todo: npm run wallet:connect

# ── Automatizar dominio mascafé.com ─────────────────────────────
# GoDaddy API: https://developer.godaddy.com/keys
GODADDY_API_KEY=
GODADDY_API_SECRET=
# GODADDY_API_ENV=ote   # solo pruebas (sandbox)

# GitHub PAT: https://github.com/settings/tokens (repo + administration)
GITHUB_TOKEN=
# GH_PAGES_PAT=           # mismo uso; nombre requerido en GitHub Secrets (no GITHUB_PAT)
# GH_TOKEN=               # alias aceptado

# npm run domain:configure
# Guía: proyecto-mas-cafe/migracion/AUTOMATIZAR-DOMINIO.md
