# Firebase — mas-cafe-c8413 (legacy — wallet ya usa Supabase)
FIREBASE_PROJECT_ID=mas-cafe-c8413

# ── Supabase wallet (plan gratuito) ─────────────────────────────
# Supabase → Settings → API
SUPABASE_URL=https://TU-REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=
# Settings → General → Reference ID (opcional si URL está arriba)
SUPABASE_PROJECT_REF=

# GitHub PAT (repo + secrets) — para npm run wallet:connect
GITHUB_TOKEN=

# Conectar todo: npm run wallet:connect

# ── Automatizar dominio mascafé.com ─────────────────────────────
# GoDaddy API: https://developer.godaddy.com/keys
GODADDY_API_KEY=
GODADDY_API_SECRET=
# GODADDY_API_ENV=ote   # solo pruebas (sandbox)

# GitHub PAT: https://github.com/settings/tokens (repo + administration)
GITHUB_TOKEN=
# GH_PAGES_PAT=           # mismo uso; nombre requerido en GitHub Secrets (no GITHUB_PAT)
# GH_TOKEN=               # alias aceptado

# npm run domain:configure
# Guía: proyecto-mas-cafe/migracion/AUTOMATIZAR-DOMINIO.md
